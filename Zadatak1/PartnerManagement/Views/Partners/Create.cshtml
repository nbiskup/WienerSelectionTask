@model PartnerManagement.Models.PartnerCreateViewModel
@{
    ViewData["Title"] = "New partner";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">New partner</h1>
        <p class="mb-0">Enter partner identity, classification and audit data.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
</div>

<form asp-action="Create" method="post" class="form-panel">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="form-section">
        <div class="form-section-title">Partner identity</div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">Partner identifiers</div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="PartnerNumber"></label>
                <input asp-for="PartnerNumber" class="form-control" maxlength="20" />
                <small class="form-text text-muted">Exactly 20 digits.</small>
                <span asp-validation-for="PartnerNumber" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="CroatianPIN"></label>
                <input asp-for="CroatianPIN" class="form-control" maxlength="11" />
                <small class="form-text text-muted">Optional, 11 digits when entered.</small>
                <span asp-validation-for="CroatianPIN" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">Classification</div>
        <div class="form-row">
            <div class="form-group col-md-4">
                <label asp-for="PartnerTypeId"></label>
                <select asp-for="PartnerTypeId" class="form-control">
                    <option value="1">Personal</option>
                    <option value="2">Legal</option>
                </select>
                <span asp-validation-for="PartnerTypeId" class="text-danger"></span>
            </div>
            <div class="form-group col-md-4">
                <label asp-for="Gender"></label>
                <select asp-for="Gender" class="form-control">
                    <option value="N">N</option>
                    <option value="M">M</option>
                    <option value="F">F</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>
            <div class="form-group col-md-4 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="IsForeign" class="form-check-input" />
                    <label asp-for="IsForeign" class="form-check-label"></label>
                </div>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">System data</div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="ExternalCode"></label>
                <input asp-for="ExternalCode" class="form-control" maxlength="20" />
                <small class="form-text text-muted">Alphanumeric, 10 to 20 characters, unique.</small>
                <span asp-validation-for="ExternalCode" class="text-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="CreatedByUser"></label>
                <input asp-for="CreatedByUser" class="form-control" />
                <span asp-validation-for="CreatedByUser" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save partner</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}