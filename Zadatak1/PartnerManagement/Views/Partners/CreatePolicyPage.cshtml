@model PartnerManagement.Models.PolicyCreateViewModel
@using PartnerManagement.Models
@{
    ViewData["Title"] = "New policy";
    var partners = ViewBag.PartnerOptions as IReadOnlyList<PartnerOption> ?? Array.Empty<PartnerOption>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">New policy</h1>
        <p class="text-muted mb-0">Enter a policy number and policy amount for an existing partner.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
</div>

@if (partners.Count == 0)
{
    <div class="alert alert-info">Create a partner before entering policy details.</div>
}

<form asp-action="CreatePolicyPage" method="post" class="partner-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="form-group">
        <label asp-for="PartnerId">Partner</label>
        <select asp-for="PartnerId" class="form-control" disabled="@(partners.Count == 0)">
            <option value="">Select partner</option>
            @foreach (var partner in partners)
            {
                <option value="@partner.PartnerId">@partner.FullName</option>
            }
        </select>
        <span asp-validation-for="PartnerId" class="text-danger"></span>
    </div>

    <div class="form-row">
        <div class="form-group col-md-6">
            <label asp-for="PolicyNumber"></label>
            <input asp-for="PolicyNumber" class="form-control" minlength="10" maxlength="15" />
            <small class="form-text text-muted">Alphanumeric, 10 to 15 characters.</small>
            <span asp-validation-for="PolicyNumber" class="text-danger"></span>
        </div>
        <div class="form-group col-md-6">
            <label asp-for="PolicyAmount"></label>
            <input asp-for="PolicyAmount" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="PolicyAmount" class="text-danger"></span>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary" disabled="@(partners.Count == 0)">Save policy</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}